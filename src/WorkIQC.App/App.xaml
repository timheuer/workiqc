                    <Color x:Key="AccentColor">#0F6CBD</Color>
                    <Color x:Key="RailBackgroundColor">#CCF7F7FB</Color>
                    <Color x:Key="RailBorderColor">#B8D7DFEA</Color>
                    <Color x:Key="SurfaceBackgroundColor">#F5F7FB</Color>
                    <Color x:Key="SurfaceSecondaryBackgroundColor">#EEF2F8</Color>
                    <Color x:Key="SurfaceElevatedBackgroundColor">#FAFBFD</Color>
                    <Color x:Key="SurfaceBorderColor">#D4DCE7</Color>
                    <Color x:Key="ShellPrimaryTextColor">#172033</Color>
                    <Color x:Key="ShellSecondaryTextColor">#5A6880</Color>
                    <Color x:Key="ShellTertiaryTextColor">#7C879A</Color>
                    <Color x:Key="SuggestionAccentColor">#ECF4FF</Color>
                    <Color x:Key="SidebarItemBackgroundColor">#D9FCFDFE</Color>
                    <Color x:Key="SidebarItemBorderColor">#FFD7E0EB</Color>
                    <Color x:Key="SidebarItemSelectedBackgroundColor">#FFE8F0FF</Color>
                    <Color x:Key="SidebarItemSelectedBorderColor">#FFB7CCF6</Color>
                    <Color x:Key="SidebarItemSelectedPreviewColor">#FF3C4D68</Color>
                    <Color x:Key="ChatUserBubbleColor">#FFEAF2FF</Color>
                    <Color x:Key="ChatUserBorderColor">#FFC3D7FF</Color>
                    <Color x:Key="ChatAssistantBubbleColor">#FFFCFDFE</Color>
                    <Color x:Key="ChatAssistantBorderColor">#FFD9E1EC</Color>
                    <Color x:Key="ChatUserBadgeColor">#FF0F6CBD</Color>
                    <Color x:Key="ChatUserBadgeForegroundColor">#FFFFFFFF</Color>
                    <Color x:Key="ChatAssistantBadgeColor">#FFE8F0FF</Color>
                    <Color x:Key="ChatAssistantBadgeForegroundColor">#FF172033</Color>
                    <Color x:Key="SendButtonForegroundColor">#FFFFFFFF</Color>

                    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
                    <SolidColorBrush x:Key="RailBackgroundBrush" Color="{StaticResource RailBackgroundColor}" />
                    <SolidColorBrush x:Key="RailBorderBrush" Color="{StaticResource RailBorderColor}" />
                    <SolidColorBrush x:Key="SurfaceBackgroundBrush" Color="{StaticResource SurfaceBackgroundColor}" />
                    <SolidColorBrush x:Key="SurfaceSecondaryBackgroundBrush" Color="{StaticResource SurfaceSecondaryBackgroundColor}" />
                    <SolidColorBrush x:Key="SurfaceElevatedBackgroundBrush" Color="{StaticResource SurfaceElevatedBackgroundColor}" />
                    <SolidColorBrush x:Key="SurfaceBorderBrush" Color="{StaticResource SurfaceBorderColor}" />
                    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource ShellPrimaryTextColor}" />
                    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource ShellSecondaryTextColor}" />
                    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource ShellTertiaryTextColor}" />
                    <SolidColorBrush x:Key="SuggestionAccentBrush" Color="{StaticResource SuggestionAccentColor}" />
                    <SolidColorBrush x:Key="SidebarItemBackgroundBrush" Color="{StaticResource SidebarItemBackgroundColor}" />
                    <SolidColorBrush x:Key="SidebarItemBorderBrush" Color="{StaticResource SidebarItemBorderColor}" />
                    <SolidColorBrush x:Key="SidebarItemSelectedBackgroundBrush" Color="{StaticResource SidebarItemSelectedBackgroundColor}" />
                    <SolidColorBrush x:Key="SidebarItemSelectedBorderBrush" Color="{StaticResource SidebarItemSelectedBorderColor}" />
                    <SolidColorBrush x:Key="SidebarItemSelectedPreviewBrush" Color="{StaticResource SidebarItemSelectedPreviewColor}" />
                    <SolidColorBrush x:Key="ChatUserBubbleBrush" Color="{StaticResource ChatUserBubbleColor}" />
                    <SolidColorBrush x:Key="ChatUserBorderBrush" Color="{StaticResource ChatUserBorderColor}" />
                    <SolidColorBrush x:Key="ChatAssistantBubbleBrush" Color="{StaticResource ChatAssistantBubbleColor}" />
                    <SolidColorBrush x:Key="ChatAssistantBorderBrush" Color="{StaticResource ChatAssistantBorderColor}" />
                    <SolidColorBrush x:Key="ChatUserBadgeBrush" Color="{StaticResource ChatUserBadgeColor}" />
                    <SolidColorBrush x:Key="ChatUserBadgeForegroundBrush" Color="{StaticResource ChatUserBadgeForegroundColor}" />
                    <SolidColorBrush x:Key="ChatAssistantBadgeBrush" Color="{StaticResource ChatAssistantBadgeColor}" />
                    <SolidColorBrush x:Key="ChatAssistantBadgeForegroundBrush" Color="{StaticResource ChatAssistantBadgeForegroundColor}" />
                    <SolidColorBrush x:Key="SendButtonForegroundBrush" Color="{StaticResource SendButtonForegroundColor}" />
                </ResourceDictionary>

                <ResourceDictionary x:Key="Light">
                    <Color x:Key="AccentColor">#0F6CBD</Color>
                    <Color x:Key="RailBackgroundColor">#CCF7F7FB</Color>
                    <Color x:Key="RailBorderColor">#B8D7DFEA</Color>
                    <Color x:Key="SurfaceBackgroundColor">#F5F7FB</Color>
                    <Color x:Key="SurfaceSecondaryBackgroundColor">#EEF2F8</Color>
                    <Color x:Key="SurfaceElevatedBackgroundColor">#FAFBFD</Color>
                    <Color x:Key="SurfaceBorderColor">#D4DCE7</Color>
                    <Color x:Key="ShellPrimaryTextColor">#172033</Color>
                    <Color x:Key="ShellSecondaryTextColor">#5A6880</Color>
                    <Color x:Key="ShellTertiaryTextColor">#7C879A</Color>
                    <Color x:Key="SuggestionAccentColor">#ECF4FF</Color>
                    <Color x:Key="SidebarItemBackgroundColor">#D9FCFDFE</Color>
                    <Color x:Key="SidebarItemBorderColor">#FFD7E0EB</Color>
                    <Color x:Key="SidebarItemSelectedBackgroundColor">#FFE8F0FF</Color>
                    <Color x:Key="SidebarItemSelectedBorderColor">#FFB7CCF6</Color>
                    <Color x:Key="SidebarItemSelectedPreviewColor">#FF3C4D68</Color>
                    <Color x:Key="ChatUserBubbleColor">#FFEAF2FF</Color>
                    <Color x:Key="ChatUserBorderColor">#FFC3D7FF</Color>
                    <Color x:Key="ChatAssistantBubbleColor">#FFFCFDFE</Color>
                    <Color x:Key="ChatAssistantBorderColor">#FFD9E1EC</Color>
                    <Color x:Key="ChatUserBadgeColor">#FF0F6CBD</Color>
                    <Color x:Key="ChatUserBadgeForegroundColor">#FFFFFFFF</Color>
                    <Color x:Key="ChatAssistantBadgeColor">#FFE8F0FF</Color>
                    <Color x:Key="ChatAssistantBadgeForegroundColor">#FF172033</Color>
                    <Color x:Key="SendButtonForegroundColor">#FFFFFFFF</Color>

                    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
                    <SolidColorBrush x:Key="RailBackgroundBrush" Color="{StaticResource RailBackgroundColor}" />
                    <SolidColorBrush x:Key="RailBorderBrush" Color="{StaticResource RailBorderColor}" />
                    <SolidColorBrush x:Key="SurfaceBackgroundBrush" Color="{StaticResource SurfaceBackgroundColor}" />
                    <SolidColorBrush x:Key="SurfaceSecondaryBackgroundBrush" Color="{StaticResource SurfaceSecondaryBackgroundColor}" />
                    <SolidColorBrush x:Key="SurfaceElevatedBackgroundBrush" Color="{StaticResource SurfaceElevatedBackgroundColor}" />
                    <SolidColorBrush x:Key="SurfaceBorderBrush" Color="{StaticResource SurfaceBorderColor}" />
                    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource ShellPrimaryTextColor}" />
                    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource ShellSecondaryTextColor}" />
                    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource ShellTertiaryTextColor}" />
                    <SolidColorBrush x:Key="SuggestionAccentBrush" Color="{StaticResource SuggestionAccentColor}" />
                    <SolidColorBrush x:Key="SidebarItemBackgroundBrush" Color="{StaticResource SidebarItemBackgroundColor}" />
                    <SolidColorBrush x:Key="SidebarItemBorderBrush" Color="{StaticResource SidebarItemBorderColor}" />
                    <SolidColorBrush x:Key="SidebarItemSelectedBackgroundBrush" Color="{StaticResource SidebarItemSelectedBackgroundColor}" />
                    <SolidColorBrush x:Key="SidebarItemSelectedBorderBrush" Color="{StaticResource SidebarItemSelectedBorderColor}" />
                    <SolidColorBrush x:Key="SidebarItemSelectedPreviewBrush" Color="{StaticResource SidebarItemSelectedPreviewColor}" />
                    <SolidColorBrush x:Key="ChatUserBubbleBrush" Color="{StaticResource ChatUserBubbleColor}" />
                    <SolidColorBrush x:Key="ChatUserBorderBrush" Color="{StaticResource ChatUserBorderColor}" />
                    <SolidColorBrush x:Key="ChatAssistantBubbleBrush" Color="{StaticResource ChatAssistantBubbleColor}" />
                    <SolidColorBrush x:Key="ChatAssistantBorderBrush" Color="{StaticResource ChatAssistantBorderColor}" />
                    <SolidColorBrush x:Key="ChatUserBadgeBrush" Color="{StaticResource ChatUserBadgeColor}" />
                    <SolidColorBrush x:Key="ChatUserBadgeForegroundBrush" Color="{StaticResource ChatUserBadgeForegroundColor}" />
                    <SolidColorBrush x:Key="ChatAssistantBadgeBrush" Color="{StaticResource ChatAssistantBadgeColor}" />
                    <SolidColorBrush x:Key="ChatAssistantBadgeForegroundBrush" Color="{StaticResource ChatAssistantBadgeForegroundColor}" />
                    <SolidColorBrush x:Key="SendButtonForegroundBrush" Color="{StaticResource SendButtonForegroundColor}" />
                </ResourceDictionary>

                <ResourceDictionary x:Key="Dark">
                    <Color x:Key="AccentColor">#7EB8FF</Color>
                    <Color x:Key="RailBackgroundColor">#C11B2433</Color>
                    <Color x:Key="RailBorderColor">#7F46526C</Color>
                    <Color x:Key="SurfaceBackgroundColor">#CC1A2332</Color>
                    <Color x:Key="SurfaceSecondaryBackgroundColor">#C3141D2B</Color>
                    <Color x:Key="SurfaceElevatedBackgroundColor">#E7283448</Color>
                    <Color x:Key="SurfaceBorderColor">#7F46526C</Color>
                    <Color x:Key="ShellPrimaryTextColor">#F7FAFF</Color>
                    <Color x:Key="ShellSecondaryTextColor">#C8D2E1</Color>
                    <Color x:Key="ShellTertiaryTextColor">#95A4B8</Color>
                    <Color x:Key="SuggestionAccentColor">#333F597E</Color>
                    <Color x:Key="SidebarItemBackgroundColor">#E31F2B3B</Color>
                    <Color x:Key="SidebarItemBorderColor">#7F445069</Color>
                    <Color x:Key="SidebarItemSelectedBackgroundColor">#E33A4B67</Color>
                    <Color x:Key="SidebarItemSelectedBorderColor">#BF6E89BA</Color>
                    <Color x:Key="SidebarItemSelectedPreviewColor">#FFE4EBF7</Color>
                    <Color x:Key="ChatUserBubbleColor">#FF273C5A</Color>
                    <Color x:Key="ChatUserBorderColor">#FF5B78A5</Color>
                    <Color x:Key="ChatAssistantBubbleColor">#E3202A3D</Color>
                    <Color x:Key="ChatAssistantBorderColor">#7F445069</Color>
                    <Color x:Key="ChatUserBadgeColor">#FF7EB8FF</Color>
                    <Color x:Key="ChatUserBadgeForegroundColor">#FF0F1727</Color>
                    <Color x:Key="ChatAssistantBadgeColor">#FF314661</Color>
                    <Color x:Key="ChatAssistantBadgeForegroundColor">#FFF7FAFF</Color>
                    <Color x:Key="SendButtonForegroundColor">#FF0F1727</Color>

                    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
                    <SolidColorBrush x:Key="RailBackgroundBrush" Color="{StaticResource RailBackgroundColor}" />
                    <SolidColorBrush x:Key="RailBorderBrush" Color="{StaticResource RailBorderColor}" />
                    <SolidColorBrush x:Key="SurfaceBackgroundBrush" Color="{StaticResource SurfaceBackgroundColor}" />
                    <SolidColorBrush x:Key="SurfaceSecondaryBackgroundBrush" Color="{StaticResource SurfaceSecondaryBackgroundColor}" />
                    <SolidColorBrush x:Key="SurfaceElevatedBackgroundBrush" Color="{StaticResource SurfaceElevatedBackgroundColor}" />
                    <SolidColorBrush x:Key="SurfaceBorderBrush" Color="{StaticResource SurfaceBorderColor}" />
                    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource ShellPrimaryTextColor}" />
                    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource ShellSecondaryTextColor}" />
                    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource ShellTertiaryTextColor}" />
                    <SolidColorBrush x:Key="SuggestionAccentBrush" Color="{StaticResource SuggestionAccentColor}" />
                    <SolidColorBrush x:Key="SidebarItemBackgroundBrush" Color="{StaticResource SidebarItemBackgroundColor}" />
                    <SolidColorBrush x:Key="SidebarItemBorderBrush" Color="{StaticResource SidebarItemBorderColor}" />
                    <SolidColorBrush x:Key="SidebarItemSelectedBackgroundBrush" Color="{StaticResource SidebarItemSelectedBackgroundColor}" />
                    <SolidColorBrush x:Key="SidebarItemSelectedBorderBrush" Color="{StaticResource SidebarItemSelectedBorderColor}" />
                    <SolidColorBrush x:Key="SidebarItemSelectedPreviewBrush" Color="{StaticResource SidebarItemSelectedPreviewColor}" />
                    <SolidColorBrush x:Key="ChatUserBubbleBrush" Color="{StaticResource ChatUserBubbleColor}" />
                    <SolidColorBrush x:Key="ChatUserBorderBrush" Color="{StaticResource ChatUserBorderColor}" />
                    <SolidColorBrush x:Key="ChatAssistantBubbleBrush" Color="{StaticResource ChatAssistantBubbleColor}" />
                    <SolidColorBrush x:Key="ChatAssistantBorderBrush" Color="{StaticResource ChatAssistantBorderColor}" />
                    <SolidColorBrush x:Key="ChatUserBadgeBrush" Color="{StaticResource ChatUserBadgeColor}" />
                    <SolidColorBrush x:Key="ChatUserBadgeForegroundBrush" Color="{StaticResource ChatUserBadgeForegroundColor}" />
                    <SolidColorBrush x:Key="ChatAssistantBadgeBrush" Color="{StaticResource ChatAssistantBadgeColor}" />
                    <SolidColorBrush x:Key="ChatAssistantBadgeForegroundBrush" Color="{StaticResource ChatAssistantBadgeForegroundColor}" />
                    <SolidColorBrush x:Key="SendButtonForegroundBrush" Color="{StaticResource SendButtonForegroundColor}" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <CornerRadius x:Key="RailCorners">24</CornerRadius>
            <CornerRadius x:Key="SurfaceCorners">24</CornerRadius>
            <CornerRadius x:Key="CardCorners">18</CornerRadius>
            <CornerRadius x:Key="ComposerCorners">20</CornerRadius>
            <CornerRadius x:Key="SmallCorners">12</CornerRadius>

            <x:Double x:Key="TitleFontSize">30</x:Double>
            <x:Double x:Key="SubtitleFontSize">15</x:Double>
            <x:Double x:Key="BodyFontSize">14</x:Double>
            <x:Double x:Key="CaptionFontSize">12</x:Double>

            <Style x:Key="SectionHeader" TargetType="TextBlock">
                <Setter Property="FontSize" Value="{StaticResource CaptionFontSize}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{ThemeResource TextTertiaryBrush}" />
                <Setter Property="CharacterSpacing" Value="20" />
            </Style>

            <Style x:Key="NavRailButton" TargetType="Button">
                <Setter Property="Padding" Value="14,10" />
                <Setter Property="CornerRadius" Value="{StaticResource SmallCorners}" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="BorderBrush" Value="{ThemeResource SurfaceBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Background" Value="{ThemeResource SurfaceElevatedBackgroundBrush}" />
                <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
            </Style>

            <Style x:Key="SubtleButton" TargetType="Button">
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="CornerRadius" Value="{StaticResource SmallCorners}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
            </Style>

            <Style x:Key="SuggestionCard" TargetType="Button">
                <Setter Property="Background" Value="{ThemeResource SurfaceElevatedBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource SurfaceBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="{StaticResource CardCorners}" />
                <Setter Property="Padding" Value="20" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="MinHeight" Value="148" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
